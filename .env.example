# Numanski mail-endpoint — kopieer naar `.env` en zet de juiste rechten:
#   cp .env.example .env
#   chmod 600 .env
#
# `.env` staat in .gitignore en mag NOOIT worden gecommit.
# Het App Password staat NIET in dit bestand — zie ./secrets/smtp_pass.

# ─── Gmail / Workspace SMTP-account (afzender + verbindings-user) ────
SMTP_USER=support@numanski.nl

# ─── Waar de mails naartoe gaan ──────────────────────────────────────
# Mag dezelfde zijn als SMTP_USER. Reply-To wordt automatisch de bezoeker.
MAIL_TO=support@numanski.nl

# ─── Welke origin mag POSTen — exact moet matchen op de Origin-header ─
ALLOWED_ORIGIN=https://numanski.nl

# ─── App Password staat in ./secrets/smtp_pass (NIET hier) ───────────
# Aanmaken op de server:
#   mkdir -p secrets
#   $EDITOR secrets/smtp_pass        # plak de 16-cijferige Google App Password
#   chmod 700 secrets
#   chmod 600 secrets/smtp_pass
#
# Google App Password genereren:
#   myaccount.google.com → Security → 2-Step Verification → App passwords
#   Type: Mail · Device: Numanski website
